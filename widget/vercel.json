{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npx serve -p 3334",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": {
      "maxDuration": 30,
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "^/api/(health|ads)$",
      "dest": "/api/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    }
  ]
}
